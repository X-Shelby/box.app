{
    "name": "Light-Final-IP",
    "type": "light",
    "colors": {
        "editor.background": "#FFFFFF",
        "editor.foreground": "#000000",
        "editor.lineHighlightBackground": "#EFEFEF",
        "editor.selectionBackground": "#ADD6FF",
        "editorCursor.foreground": "#000000"
    },
    "tokenColors": [
        {
            "settings": {
                "foreground": "#000000"
            }
        },
        {
            "scope": ["comment", "comment.line"],
            "settings": {
                "foreground": "#808080",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["string", "string.quoted", "string.unquoted"],
            "settings": {
                "foreground": "#008080"
            }
        },
        {
            "scope": ["support.type.property-name.json"],
            "settings": {
                "foreground": "#001080"
            }
        },
        {
            "scope": ["punctuation.separator.dictionary.key-value.json"],
            "settings": {
                "foreground": "#AF00DB"
            }
        },
        {
            "scope": ["constant.language.json"],
            "settings": {
                "foreground": "#0000FF",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["constant.numeric.json"],
            "settings": {
                "foreground": "#098658"
            }
        },
        {
            "scope": "constant.numeric",
            "settings": {
                "foreground": "#098658"
            }
        },
        {
            "scope": ["constant.language.boolean.true", "constant.language.truthy"],
            "settings": {
                "foreground": "#0000FF",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["constant.language.boolean.false", "constant.language.falsy"],
            "settings": {
                "foreground": "#A31515",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "constant.language.null",
            "settings": {
                "foreground": "#0000FF",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["entity.name.tag", "support.type.property-name"],
            "settings": {
                "foreground": "#001080"
            }
        },
        {
            "scope": ["variable.other.property"],
            "settings": {
                "foreground": "#001080"
            }
        },
        {
            "scope": ["variable.other.anchor", "variable.other.alias"],
            "settings": {
                "foreground": "#A31515",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "variable.other.substitution",
            "settings": {
                "foreground": "#795E26"
            }
        },
        {
            "scope": "constant.other.ip-address",
            "settings": {
                "foreground": "#267F99",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["string.other.url", "markup.underline.link"],
            "settings": {
                "foreground": "#0000EE",
                "fontStyle": "underline"
            }
        },
        {
            "scope": "string.other.path",
            "settings": {
                "foreground": "#008080"
            }
        },
        {
            "scope": ["entity.name.section", "entity.name.section.ini"],
            "settings": {
                "foreground": "#795E26",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "punctuation.definition.list.begin",
            "settings": {
                "foreground": "#AF00DB"
            }
        },
        {
            "scope": ["punctuation.separator", "punctuation.separator.key-value"],
            "settings": {
                "foreground": "#AF00DB"
            }
        },
        {
            "scope": "constant.character.escape",
            "settings": {
                "foreground": "#EE0000",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "invalid.illegal",
            "settings": {
                "foreground": "#FF0000",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "meta.directive",
            "settings": {
                "foreground": "#808000"
            }
        }
    ]
}