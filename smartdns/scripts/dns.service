#!/system/bin/sh

# ── 加载配置（路径变量 + 用户配置均在 setting.conf 中定义）──
. /data/adb/smartdns/setting.conf

SMARTDNS_CPU_AFFINITY="${CPU_AFFINITY:-0-5}"

log() {
    local time
    time=$(date "+%Y-%m-%d %H:%M:%S")
    echo "$1"
    if [ "$2" ]; then
        echo "[$time]: $1" > "$RUN_PATH/module.log"
    else
        echo "[$time]: $1" >> "$RUN_PATH/module.log"
    fi
}

description() {
    local file_path="$MODULE_PATH/module.prop"
    if pidof "$SMARTDNS_BIN" > /dev/null 2>&1; then
        sed -i "s/🔴已停止/🟢已运行/g" "$file_path"
    else
        sed -i "s/🟢已运行/🔴已停止/g" "$file_path"
    fi
    log "更新模块描述"
}

get_pid() {
    pidof "$SMARTDNS_BIN"
}

is_running() {
    [ -n "$(get_pid)" ]
}

set_oom() {
    local pid="$1"
    if [ "${OOM_PROTECT:-true}" = "true" ]; then
        echo -17    > /proc/$pid/oom_adj       2>/dev/null \
            && echo -1000 > /proc/$pid/oom_score_adj 2>/dev/null \
            && log "OOM 保护设置成功 (oom_adj=-17, oom_score_adj=-1000)" \
            || log "OOM 保护设置失败，请检查权限"
    else
        log "OOM 保护已禁用，跳过"
    fi
}

smartdns_start() {
    if is_running; then
        log "SmartDNS 已在运行 (PID: $(get_pid))"
        return 0
    fi

    log "正在启动 SmartDNS (CPU 核心: $SMARTDNS_CPU_AFFINITY)..."

    nohup $BUSYBOX_BIN taskset -c "$SMARTDNS_CPU_AFFINITY" \
        $BUSYBOX_BIN chpst -u 0:3004 \
        "$BIN_PATH/run-smartdns" -c "$SMARTDNS_CONF" -p - \
        > "$RUN_PATH/$SMARTDNS_BIN.log" 2>&1 &

    sleep 1

    if is_running; then
        local pid
        pid=$(get_pid)
        log "SmartDNS 启动成功 (PID: $pid)"
        set_oom "$pid"
    else
        log "SmartDNS 启动失败，请检查日志: $RUN_PATH/$SMARTDNS_BIN.log"
        return 1
    fi
}

smartdns_stop() {
    local pid
    pid=$(get_pid)

    if [ -z "$pid" ]; then
        log "SmartDNS 已处于停止状态"
        return 0
    fi

    log "正在关闭 SmartDNS (PID: $pid)..."

    kill "$pid" 2>/dev/null
    sleep 1

    if is_running; then
        log "进程未响应，强制终止..."
        kill -9 "$pid" 2>/dev/null
        sleep 1
    fi

    if is_running; then
        log "SmartDNS 关闭失败"
        return 1
    else
        log "SmartDNS 关闭成功"
    fi
}

cron_start() {
    if [ "${RULE_AUTO_UPDATE:-false}" = "true" ]; then
        "$SCRIPTS_PATH/dns.tool" cron > /dev/null 2>&1
    fi
}

cron_stop() {    
    $BUSYBOX_BIN pkill -f "crond.*${RUN_PATH%/*}" 2>/dev/null           
       
    $BUSYBOX_BIN crontab -c "$RUN_PATH" -r 2>/dev/null
}

start() {
    smartdns_start
    cron_start
    description
}

stop() {
    smartdns_stop
    cron_stop
    description
}

restart() {
    log "stop >"
    stop
    log "< stop"
    sleep 1
    log "start >"
    start
    log "< start"
}

case "$1" in
    start)
        log "start >>>" "start"
        start
        log "<<< end"
        ;;
    stop)
        log "stop >>>" "stop"
        stop
        log "<<< end"
        ;;
    restart)
        log "restart >>>" "restart"
        restart
        log "<<< end"
        ;;
    *)
        echo "使用: $0 start(启动) | stop(停止) | restart(重启)"
        exit 1
        ;;
esac
