#!/system/bin/sh

. /data/adb/smartdns/setting.conf

LOG="$RUN_PATH/module.log"

events="$1"
monitor_file="$3"

log_msg() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG"
}

[ "$monitor_file" = "disable" ] || exit 0

case "$events" in
    n)
        log_msg "disable 文件创建，停止 SmartDNS"
        "$SCRIPTS_PATH/dns.service" stop > "$LOG" 2>&1
        ;;
    d)
        log_msg "disable 文件删除，启动 SmartDNS"
        "$SCRIPTS_PATH/dns.service" start > "$LOG" 2>&1
        ;;
esac
